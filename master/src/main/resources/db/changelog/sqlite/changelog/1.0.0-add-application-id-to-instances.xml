<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="sqlite-1.0.0-add-application-id-to-instances" author="Axelix Team">

    <preConditions onFail="MARK_RAN" onError="HALT">
      <not>
        <columnExists tableName="instances" columnName="group_id"/>
        <columnExists tableName="instances" columnName="artifact_id"/>
      </not>
    </preConditions>

    <addColumn tableName="instances">
      <column name="group_id" type="TEXT">
        <constraints nullable="false"/>
      </column>
      <column name="artifact_id" type="TEXT">
        <constraints nullable="false"/>
      </column>
    </addColumn>
  </changeSet>
</databaseChangeLog>
