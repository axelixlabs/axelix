<?xml version="1.0" encoding="UTF-8"?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="
            http://www.liquibase.org/xml/ns/dbchangelog
            http://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-latest.xsd">

  <changeSet id="mysql-1.0.0-add-persistence-insights-to-historical-application-snapshots" author="Axelix Team">
    <preConditions onFail="MARK_RAN" onError="HALT">
      <not>
        <columnExists tableName="historical_application_snapshots" columnName="persistence_insights"/>
      </not>
    </preConditions>

    <addColumn tableName="historical_application_snapshots">
      <column name="persistence_insights" type="TEXT">
        <constraints nullable="true"/>
      </column>
    </addColumn>
  </changeSet>
</databaseChangeLog>
